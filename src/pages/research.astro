---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllPublications } from '@/lib/data-utils'
import { Image } from 'astro:assets'

const publications = await getAllPublications()

const renderAuthors = (authors: string) =>
  authors.replace(/\*\*(.+?)\*\*/g, '<strong class="text-foreground">$1</strong>')
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Research" />
  <Breadcrumbs
    items={[{ label: 'Research', icon: 'lucide:graduation-cap' }]}
  />

  <section class="flex flex-col gap-4">
    <p class="text-muted-foreground text-sm">
      Recent publications. Full list on <Link
        href="https://scholar.google.com.br/citations?user=PqZyPqoAAAAJ&hl=en"
        class="text-foreground decoration-muted-foreground hover:decoration-foreground underline underline-offset-[3px]"
        external>Google Scholar</Link
      >.
    </p>

    <ul class="flex flex-col gap-4" role="list">
      {
        publications.map((pub) => (
          <li
            id={pub.id}
            class="border-border/40 bg-background/40 hover:border-foreground/40 hover:bg-background/60 rounded-2xl border p-4 backdrop-blur-sm transition-[background-color,border-color] duration-300 ease-in-out"
          >
            <Link
              href={`/research/${pub.id}`}
              class="flex flex-col gap-4 sm:flex-row-reverse sm:items-start"
            >
              {pub.data.image && (
                <div class="w-full sm:w-52 sm:shrink-0">
                  <Image
                    src={pub.data.image}
                    alt={pub.data.title}
                    width={600}
                    height={400}
                    class="aspect-video w-full rounded-xl object-cover"
                  />
                </div>
              )}
              <div class="grow">
                <h3 class="mb-1 text-lg leading-6 font-medium">
                  {pub.data.title}
                </h3>
                <p
                  class="text-muted-foreground mb-1 text-sm"
                  set:html={renderAuthors(pub.data.authors)}
                />
                <p class="text-muted-foreground/70 mb-2 text-xs">
                  {pub.data.venue} &middot; {pub.data.date.getFullYear()}
                </p>
                {pub.data.abstract && (
                  <p class="text-muted-foreground text-sm">
                    {pub.data.abstract}
                  </p>
                )}
              </div>
            </Link>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
