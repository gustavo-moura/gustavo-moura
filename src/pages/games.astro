---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllGames } from '@/lib/data-utils'

const games = await getAllGames()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Games" />
  <Breadcrumbs items={[{ label: 'Games', icon: 'lucide:gamepad-2' }]} />

  <section class="flex flex-col gap-4">
    <p class="text-muted-foreground text-sm">
      Games I've shipped or contributed to over the years.
    </p>

    <div class="flex flex-col gap-4">
      {games.map((game) => <ProjectCard project={game} />)}
    </div>
  </section>
</Layout>
