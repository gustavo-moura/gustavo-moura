---
import Badge from '@/components/Badge.astro'
import Link from '@/components/Link.astro'
import { Separator } from '@/components/ui/separator'
import { extractDomain, formatMonthYear } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'games'>
}

const { project } = Astro.props
---

<div
  class="border-border/40 bg-background/40 hover:border-foreground/40 hover:bg-background/60 rounded-2xl border p-4 backdrop-blur-sm transition-[background-color,border-color] duration-300 ease-in-out"
>
  <Link
    href={`/games/${project.id}`}
    class="flex flex-col gap-4 sm:flex-row-reverse sm:items-start"
  >
    {
      project.data.image && (
        <div class="w-full sm:w-52 sm:shrink-0">
          <Image
            src={project.data.image}
            alt={project.data.name}
            width={1200}
            height={630}
            class="aspect-video w-full rounded-xl object-cover"
          />
        </div>
      )
    }
    <div class="grow">
      <h3 class="mb-1 text-lg font-medium">
        {project.data.name}
      </h3>
      <p class="text-muted-foreground mb-2 text-sm">
        {project.data.description}
      </p>
      <div class="text-muted-foreground/60 mb-2 flex flex-wrap items-center gap-x-2 text-xs">
        <span class="flex items-center gap-x-1">
          <Icon name="lucide:external-link" class="size-3" />
          <span>{extractDomain(project.data.link)}</span>
        </span>
      </div>
      {
        project.data.tags && (
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <Badge text={tag} />
            ))}
          </div>
        )
      }
    </div>
  </Link>
</div>
