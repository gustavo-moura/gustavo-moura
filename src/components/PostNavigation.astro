---
import Link from '@/components/Link.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

const { newerPost, olderPost, parentPost } = Astro.props
const isSubpost = !!parentPost

const pill =
  'text-muted-foreground hover:text-foreground border-border/40 bg-background/40 hover:border-foreground/40 hover:bg-background/60 inline-flex max-w-[14rem] items-center gap-1.5 rounded-full border px-3 py-1 text-xs backdrop-blur-sm transition-[background-color,border-color,color]'
const disabled = 'pointer-events-none opacity-40'
---

<nav class="col-start-2 flex items-center justify-between gap-3">
  <Link
    href={olderPost ? `/blog/${olderPost.id}#post-title` : '#'}
    class={cn('group', pill, !olderPost && disabled)}
    aria-disabled={!olderPost}
  >
    <Icon
      name="lucide:arrow-left"
      class="size-3 shrink-0 transition-transform group-hover:-translate-x-0.5"
    />
    <span class="truncate">
      {
        olderPost?.data.title ||
          (isSubpost ? 'No older subpost' : 'Oldest post')
      }
    </span>
  </Link>

  {
    isSubpost && (
      <Link
        href={parentPost ? `/blog/${parentPost.id}#post-title` : '#'}
        class={cn('group', pill, !parentPost && disabled)}
      >
        <Icon
          name="lucide:corner-left-up"
          class="size-3 shrink-0 transition-transform group-hover:-translate-y-0.5"
        />
        <span class="truncate">{parentPost?.data.title || 'No parent'}</span>
      </Link>
    )
  }

  <Link
    href={newerPost ? `/blog/${newerPost.id}#post-title` : '#'}
    class={cn('group', pill, !newerPost && disabled)}
    aria-disabled={!newerPost}
  >
    <span class="truncate">
      {
        newerPost?.data.title ||
          (isSubpost ? 'No newer subpost' : 'Newest post')
      }
    </span>
    <Icon
      name="lucide:arrow-right"
      class="size-3 shrink-0 transition-transform group-hover:translate-x-0.5"
    />
  </Link>
</nav>
