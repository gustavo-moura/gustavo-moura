---
import '@/styles/global.css'
import '@/styles/typography.css'

import Footer from '@/components/Footer.astro'
import Head from '@/components/Head.astro'
import Header from '@/components/Header.astro'
import { SITE } from '@/consts'
import { cn } from '@/lib/utils'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<!doctype html>
<html
  class="bg-background text-foreground scheme-dark"
  lang={SITE.locale}
  data-theme="dark"
>
  <Head>
    <slot name="head" />
  </Head>
  <body>
    <div class="aurora" aria-hidden="true">
      <div class="aurora-blob aurora-blob-purple"></div>
      <div class="aurora-blob aurora-blob-green"></div>
      <div class="aurora-blob aurora-blob-blue"></div>
      <div class="aurora-blob aurora-blob-pink"></div>
      <div class="aurora-blob aurora-blob-indigo"></div>
      <div class="aurora-mask"></div>
    </div>
    <div class="relative z-10 flex h-fit min-h-screen flex-col gap-y-6 font-sans">
      <div
        class="group sticky top-0 z-50"
        data-site-header
      >
        <Header />
        <slot name="subposts-navigation" />
        <slot name="table-of-contents" />
      </div>
      <main class="grow">
        <div class={cn('mx-auto flex grow flex-col gap-y-6 px-4', className)}>
          <slot />
        </div>
      </main>
      <Footer />
    </div>
    <script>
      const header = document.querySelector<HTMLElement>('[data-site-header]')
      const update = () => {
        if (!header) return
        header.dataset.scrolled = window.scrollY > 16 ? 'true' : 'false'
      }
      update()
      window.addEventListener('scroll', update, { passive: true })
    </script>
  </body>
</html>
